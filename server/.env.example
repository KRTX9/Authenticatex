# Django Settings
SECRET_KEY=CHANGE_ME_generate_a_random_50char_string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development)
USE_MYSQL=False
DB_NAME=authservice
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Settings
# Access token: 1 hour (60 minutes) - Auto-refreshes in background
# Refresh token: 7 days (10080 minutes) - Must re-login after 7 days
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=10080

# Email Configuration (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SecureAuth <noreply@secureauth.com>
EMAIL_VERIFICATION_REQUIRED=True

# Google OAuth2
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Encryption Key for MFA Secrets (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MFA_ENCRYPTION_KEY=

